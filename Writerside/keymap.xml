<?xml version="1.0" encoding="UTF-8"?>
<keymap id="my_keymap">
    <layouts>
        <layout name="Windows" platform="PC"/>
        <layout name="macOS" platform="MAC"/>
        <layout name="Linux" platform="PC"/>
    </layouts>
    <actions>
        <action id="$Copy">
            <description>复制</description>
            <shortcut layout="Windows">Ctrl+C</shortcut>
            <shortcut layout="macOS">⌘ C</shortcut>
            <shortcut layout="Linux">Ctrl+C</shortcut>
        </action>
        <action id="$Paste">
            <description>粘贴</description>
            <shortcut layout="Windows">Ctrl+V</shortcut>
            <shortcut layout="macOS">⌘ V</shortcut>
            <shortcut layout="Linux">Ctrl+V</shortcut>
        </action>
        <action id="$idea-insert">
            <description>插入，MacOS 键位存疑</description>
            <shortcut layout="Windows">alt+insert</shortcut>
            <shortcut layout="macOS">⌘ N</shortcut>
            <shortcut layout="Linux">alt+insert</shortcut>
        </action>
    </actions>
</keymap>